# Configure these as server-side secrets for the API service. Never prefix them
# with VITE_ and never commit a populated .env file.
RESEND_API_KEY=re_replace_with_your_resend_api_key
QUOTE_FROM_EMAIL=Arzana Website <quotes@your-verified-domain.com>
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_your_server_only_service_role_key

# Public browser configuration for the shared Supabase catalog.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_with_your_key

# The quote recipient is intentionally fixed in the API to:
# m.saadi@arzanaco.com
